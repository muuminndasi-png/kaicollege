generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  password      String
  role          String   @default("student")
  relatedId     String?
  firstName     String   @default("")
  lastName      String   @default("")
  email         String?
  phone         String?
  profilePhoto  String?
  isActive      Boolean  @default(true)
  mustChangePassword Boolean @default(true)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions     Session[]
  auditLogs    AuditLog[]
}

model Student {
  id            String   @id @default(cuid())
  regNumber     String   @unique
  firstName     String
  middleName    String?
  lastName      String
  email         String?
  phone         String?
  gender        String   @default("Male")
  dateOfBirth   String?
  address       String?
  courseId      String
  year          Int      @default(1)
  semester      Int      @default(1)
  intake        String   @default("March")
  status        String   @default("Active")
  enrollmentDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course                Course                  @relation(fields: [courseId], references: [id])
  results               ExamResult[]
  payments              FeePayment[]
  permissions           ResultPermission[]
  quizSubmissions       QuizSubmission[]
  assignmentSubmissions AssignmentSubmission[]
  semesterHistory       SemesterHistory[]
}

model Teacher {
  id          String   @id @default(cuid())
  employeeId  String   @unique
  firstName   String
  middleName  String?
  lastName    String
  email       String?
  phone       String?
  gender      String   @default("Male")
  qualification String?
  department  String
  specialization String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subjects    Subject[]
  materials   CourseMaterial[]
  quizzes     Quiz[]
  assignments Assignment[]
}

model Course {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  duration    String   @default("3 Years")
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students Student[]
  subjects Subject[]
  alumni  Alumni[]
  transcriptBatches TranscriptBatch[]
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  code        String
  courseId    String
  teacherId   String?
  credits     Int      @default(3)
  semester    Int      @default(1)
  year        Int      @default(1)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course          @relation(fields: [courseId], references: [id])
  teacher     Teacher?        @relation(fields: [teacherId], references: [id])
  results     ExamResult[]
  materials   CourseMaterial[]
  quizzes     Quiz[]
  assignments Assignment[]
}

model ExamResult {
  id          String   @id @default(cuid())
  studentId   String
  subjectId   String
  examType    String   @default("Final")
  marks       Float
  grade       String
  points      Float
  semester    Int      @default(1)
  year        Int      @default(1)
  academicYear String?
  remarks     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
}

model FeePayment {
  id            String   @id @default(cuid())
  studentId     String
  amount        Float
  paymentType   String   @default("Tuition")
  semester      Int      @default(1)
  year          Int      @default(1)
  academicYear  String?
  method        String   @default("Cash")
  receiptNumber String?
  status        String   @default("Paid")
  paidDate      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])
}

model FeeStructure {
  id          String   @id @default(cuid())
  courseId    String
  year        Int      @default(1)
  semester    Int      @default(1)
  feeType     String   @default("Tuition")
  amount      Float
  description String?
  academicYear String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Alumni {
  id            String   @id @default(cuid())
  alumniNumber  String   @unique
  regNumber     String
  firstName     String
  middleName    String?
  lastName      String
  email         String?
  phone         String?
  gender        String   @default("Male")
  courseId      String
  courseName    String
  graduationYear String
  graduationDate String?
  gpa           Float    @default(0)
  classHonour   String   @default("Pass")
  currentEmployer String?
  currentPosition  String?
  currentLocation  String?
  linkedin      String?
  status        String   @default("Active")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id])
}

model ResultPermission {
  id               String   @id @default(cuid())
  studentId        String   @unique
  transcript       Boolean  @default(false)
  resultStatement  Boolean  @default(false)
  grantedBy        String?
  grantedDate      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model CourseMaterial {
  id            String   @id @default(cuid())
  teacherId     String
  subjectId     String
  title         String
  description   String?
  fileUrl       String?
  fileName      String?
  fileType      String?
  fileSize      Int?
  targetYear    Int?
  targetSemester Int?
  downloads     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teacher  Teacher  @relation(fields: [teacherId], references: [id])
  subject  Subject  @relation(fields: [subjectId], references: [id])
}

model Quiz {
  id            String   @id @default(cuid())
  teacherId     String
  subjectId     String
  title         String
  description   String?
  durationMinutes Int     @default(30)
  totalMarks    Float    @default(100)
  dueDate       DateTime?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teacher     Teacher          @relation(fields: [teacherId], references: [id])
  subject     Subject          @relation(fields: [subjectId], references: [id])
  questions   QuizQuestion[]
  submissions QuizSubmission[]
}

model QuizQuestion {
  id            String   @id @default(cuid())
  quizId        String
  question      String
  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  correctAnswer String?
  marks         Float    @default(10)
  questionOrder Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizSubmission {
  id            String   @id @default(cuid())
  quizId        String
  studentId     String
  score         Float    @default(0)
  totalMarks    Float    @default(0)
  answers       String
  timeStarted   DateTime?
  timeSubmitted DateTime?
  status        String   @default("submitted")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  quiz    Quiz    @relation(fields: [quizId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
}

model Assignment {
  id            String   @id @default(cuid())
  teacherId     String
  subjectId     String
  title         String
  description   String?
  totalMarks    Float    @default(100)
  dueDate       DateTime?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teacher     Teacher                @relation(fields: [teacherId], references: [id])
  subject     Subject                @relation(fields: [subjectId], references: [id])
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id            String   @id @default(cuid())
  assignmentId  String
  studentId     String
  content       String?
  fileUrl       String?
  fileName      String?
  marks         Float?
  feedback      String?
  submittedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id])
}

model Notification {
  id            String   @id @default(cuid())
  userId        String
  title         String
  message       String
  type          String   @default("info")
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SemesterHistory {
  id            String   @id @default(cuid())
  studentId     String
  fromYear      Int
  fromSemester  Int
  toYear        Int
  toSemester    Int
  reason        String?
  effectiveDate DateTime @default(now())
  approvedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  deviceInfo   String?
  ipAddress    String?
  location     String?
  userAgent    String?
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  isValid      Boolean  @default(true)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  details    String?
  ipAddress  String?
  location   String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model TranscriptBatch {
  id           String   @id @default(cuid())
  title        String
  courseId     String?
  year         Int?
  semester     Int?
  academicYear String?
  status       String   @default("draft")
  generatedBy  String?
  generatedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  studentCount Int      @default(0)

  course Course? @relation(fields: [courseId], references: [id])
}

model ResultLock {
  id            String   @id @default(cuid())
  courseId      String?
  year          Int?
  semester      Int?
  studentId     String?
  lockType      String   // "class" or "individual"
  reason        String?
  lockedBy      String?
  isLocked      Boolean  @default(true)
  lockedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
